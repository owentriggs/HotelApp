{
  "name": "hotelapp",
  "version": "0.1.0",
  "description": "Small hotel booking, guest, room and POS management app",
  "main": "dist-electron/main/index.js",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build:renderer": "tsc -p tsconfig.json --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "start": "npm run build && electron .",
    "dev:electron": "npm run build:electron && cross-env HOTELAPP_DEV_SERVER=1 electron .",
    "rebuild": "electron-rebuild -w better-sqlite3",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac --x64",
    "dist:win": "npm run build && electron-builder --win",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^4.36.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^18.19.50",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^10.1.0",
    "electron": "^25.9.8",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.4",
    "vite": "^4.5.5",
    "vitest": "^0.34.6"
  }
}
